<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-2 d-md-block sidebar fixed" style="background-color: #2C3E50; min-height: 100vh;">
                <div class="position-sticky pt-3">
                    <div class="text-center mb-4">
                        <i class="fas fa-store fa-3x" style="color: #27AE60;"></i>
                        <h5 class="text-white mt-2">Admin Panel</h5>
                        <hr style="background-color: #27AE60;">
                    </div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Admin/Dashboard">
                                <i class="fas fa-tachometer-alt me-2" style="color: #27AE60;"></i>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Admin/ProductList">
                                <i class="fas fa-box me-2" style="color: #27AE60;"></i>
                                Products
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Admin/AddProduct">
                                <i class="fas fa-plus-circle me-2" style="color: #27AE60;"></i>
                                Add Product
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Admin/OrderList">
                                <i class="fas fa-shopping-cart me-2" style="color: #27AE60;"></i>
                                Orders
                            </a>
                        </li>
                        <li class="nav-item mt-4">
                            <a class="nav-link text-white" href="/Account/Logout">
                                <i class="fas fa-sign-out-alt me-2" style="color: #27AE60;"></i>
                                Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-10 ms-sm-auto px-md-4">

<div class="pt-3 pb-2 mb-3 border-bottom">

@if (ViewData["Title"]?.ToString() != "Admin Dashboard")
{
<a href="javascript:history.back()" class="btn btn-secondary mb-3">
<i class="fas fa-arrow-left"></i> Back
</a>
}

<h1 class="h2" style="color: #2C3E50;">@ViewData["Title"]</h1>

</div>

@RenderBody()

</main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
