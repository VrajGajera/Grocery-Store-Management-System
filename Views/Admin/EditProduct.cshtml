@model Grosary_net.Models.Product

@{
    ViewData["Title"] = "Edit Product";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-header" style="background-color: #2C3E50; color: white;">
                <h5 class="mb-0">Edit Product</h5>
            </div>
            <div class="card-body">
                <form asp-action="EditProduct" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AddedDate" />

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label" style="color: #2C3E50;"></label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label" style="color: #2C3E50;"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label" style="color: #2C3E50;"></label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="StockQuantity" class="form-label" style="color: #2C3E50;"></label>
                            <input asp-for="StockQuantity" type="number" class="form-control" required />
                            <span asp-validation-for="StockQuantity" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category" class="form-label" style="color: #2C3E50;"></label>
                        <select asp-for="Category" class="form-control" required>
                            <option value="">Select Category</option>

                            <option value="Fruits" selected="@(Model.Category == "Fruits")">Fruits</option>

                            <option value="Vegetables" selected="@(Model.Category == "Vegetables")">Vegetables</option>

                            <option value="Dairy" selected="@(Model.Category == "Dairy")">Dairy</option>

                            <option value="Bakery" selected="@(Model.Category == "Bakery")">Bakery</option>

                            <option value="Beverages" selected="@(Model.Category == "Beverages")">Beverages</option>

                            <option value="Snacks" selected="@(Model.Category == "Snacks")">Snacks</option>
                            <option value="Meat" selected="@(Model.Category == "Meat")">Meat</option>
                            <option value="Seafood" selected="@(Model.Category == "Seafood")">Seafood</option>

                        </select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label" style="color: #2C3E50;"></label>
                        <input asp-for="ImageUrl" class="form-control" required />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn px-4" style="background-color: #27AE60; color: white;">
                            <i class="fas fa-save me-2"></i>Update Product
                        </button>
                        <a href="/Admin/ProductList" class="btn px-4" style="background-color: #2C3E50; color: white;">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}