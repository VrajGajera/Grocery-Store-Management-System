@model Grosary_net.Models.Product

@{
    ViewData["Title"] = "Add Product";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header" style="background-color: #2C3E50;">
                    <h5 class="text-white mb-0">
                        <i class="fas fa-plus-circle me-2" style="color: #27AE60;"></i>
                        Add New Product
                    </h5>
                </div>

                <div class="card-body">

                    <form asp-action="AddProduct" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label" style="color:#2C3E50;">Product Name</label>
                                <input asp-for="Name" class="form-control" placeholder="Enter product name" required />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Category" class="form-label" style="color:#2C3E50;">Category</label>

                                <select asp-for="Category" class="form-control" required>
                                    <option value="">Select Category</option>
                                    <option value="Fruits">Fruits</option>
                                    <option value="Vegetables">Vegetables</option>
                                    <option value="Dairy">Dairy</option>
                                    <option value="Bakery">Bakery</option>
                                    <option value="Beverages">Beverages</option>
                                    <option value="Snacks">Snacks</option>
                                    <option value="Meat">Meat</option>
                                    <option value="Seafood">Seafood</option>
                                </select>

                                <span asp-validation-for="Category" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label" style="color:#2C3E50;">Description</label>

                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Enter product description"
                                      required></textarea>

                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label asp-for="Price" class="form-label" style="color:#2C3E50;">Price ($)</label>

                                <input asp-for="Price"
                                       type="number"
                                       step="0.01"
                                       class="form-control"
                                       placeholder="0.00"
                                       required />

                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="StockQuantity" class="form-label" style="color:#2C3E50;">Stock Quantity</label>

                                <input asp-for="StockQuantity"
                                       type="number"
                                       class="form-control"
                                       placeholder="0"
                                       required />

                                <span asp-validation-for="StockQuantity" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="ImageUrl" class="form-label" style="color:#2C3E50;">Image URL</label>

                                <input asp-for="ImageUrl"
                                       id="ImageUrl"
                                       class="form-control"
                                       placeholder="https://example.com/image.jpg"
                                       required />

                                <span asp-validation-for="ImageUrl" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="color:#2C3E50;">Image Preview</label>

                            <div class="border rounded p-3 text-center"
                                 id="imagePreview"
                                 style="background-color:#f8f9fa;">

                                <img src="https://via.placeholder.com/200x200?text=No+Image"
                                     alt="Preview"
                                     class="img-fluid"
                                     style="max-height:200px;"
                                     id="previewImg">
                            </div>
                        </div>

                        <div class="text-center mt-4">

                            <button type="submit"
                                    class="btn px-4"
                                    style="background-color:#27AE60; color:white;">

                                <i class="fas fa-save me-2"></i>
                                Save Product
                            </button>

                            <a href="/Admin/ProductList"
                               class="btn px-4"
                               style="background-color:#2C3E50; color:white;">

                                <i class="fas fa-times me-2"></i>
                                Cancel
                            </a>

                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

<script>

document.getElementById('ImageUrl').addEventListener('input', function () {

    var preview = document.getElementById('previewImg');

    preview.src = this.value || 'https://via.placeholder.com/200x200?text=No+Image';

});

</script>

@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

}