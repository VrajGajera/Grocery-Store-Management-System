@model Grosary_net.Models.User

@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header" style="background-color: #2C3E50;">
                    <h4 class="text-white mb-0">
                        <i class="fas fa-user-plus me-2" style="color: #27AE60;"></i>
                        Create New Account
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Register" method="post" autocomplete="off">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label" style="color: #2C3E50;">Full Name</label>
                            <input asp-for="FullName" class="form-control" autocomplete="off" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label" style="color: #2C3E50;">Email</label>
                            <input asp-for="Email" type="email" class="form-control" autocomplete="off" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label" style="color: #2C3E50;">Username</label>
                            <input asp-for="Username" class="form-control" autocomplete="off" required />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label" style="color: #2C3E50;">Password</label>
                            <input asp-for="Password" type="password" class="form-control" autocomplete="off" required />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn w-100" style="background-color: #27AE60; color: white; padding: 10px;">
                            <i class="fas fa-user-check me-2"></i>Register
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <p>Already have an account? <a href="/Account/SignIn" style="color: #27AE60;">Sign In</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}