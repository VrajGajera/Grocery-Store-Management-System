@{
    ViewData["Title"] = "Sign In";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow">
                <div class="card-header" style="background-color: #2C3E50;">
                    <h4 class="text-white mb-0">
                        <i class="fas fa-sign-in-alt me-2" style="color: #27AE60;"></i>
                        Sign In
                    </h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form method="post" action="/Account/Login" autocomplete="off">
                        <div class="mb-3">
                            <label class="form-label" style="color: #2C3E50;">Username</label>
                            <input type="text" name="username" class="form-control" placeholder="Enter username" autocomplete="off" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" style="color: #2C3E50;">Password</label>
                            <input type="password" name="password" class="form-control" placeholder="Enter password" autocomplete="off" required />
                        </div>
                        <button type="submit" class="btn w-100" style="background-color: #27AE60; color: white; padding: 10px;">
                            <i class="fas fa-sign-in-alt me-2"></i>Sign In
                        </button>
                    </form>

                    <hr class="my-4">

                    <div class="text-center">
                        <p>Don't have an account? <a href="/Account/Register" style="color: #27AE60; font-weight: 600;">Register here</a></p>
                    </div>

                    <div class="alert alert-info mt-3">
                        <small>
                            <strong>Demo Credentials:</strong><br>
                            Username: <strong>john</strong><br>
                            Password: <strong>john123</strong>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>