<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Contact Us</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

/* CONTACT PAGE */

body{
font-family: Arial, Helvetica, sans-serif;
background:#f4f6f9;
margin:0;
padding:0;
}

.contact-section{
padding:60px 0;
}

.container{
width:90%;
max-width:1100px;
margin:auto;
}

.contact-title{
font-weight:700;
color:#2c3e50;
margin-bottom:10px;
}

.contact-title i{
color:#27ae60;
margin-right:10px;
}

.contact-subtitle{
color:#777;
margin-bottom:30px;
}

.row{
display:flex;
gap:40px;
flex-wrap:wrap;
}

.col{
flex:1;
min-width:300px;
}

.contact-card{
background:white;
padding:35px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.08);
}

.contact-card label{
font-weight:600;
display:block;
margin-top:10px;
}

.contact-card input,
.contact-card textarea{
width:100%;
border-radius:8px;
border:1px solid #ddd;
padding:10px;
margin-top:5px;
margin-bottom:15px;
transition:0.3s;
}

.contact-card input:focus,
.contact-card textarea:focus{
border-color:#27ae60;
box-shadow:0 0 5px rgba(39,174,96,0.4);
outline:none;
}

.contact-btn{
background:#27ae60;
border:none;
padding:10px 25px;
border-radius:6px;
font-weight:600;
color:white;
cursor:pointer;
transition:0.3s;
}

.contact-btn:hover{
background:#1e8449;
}

.store-info{
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.08);
}

.store-info h4{
font-weight:700;
margin-bottom:20px;
}

.store-info i{
color:#27ae60;
margin-right:10px;
}

.store-info p{
margin-bottom:10px;
font-size:15px;
color:#555;
}

</style>

</head>

<body>

<div class="contact-section">

<div class="container">

<h2 class="contact-title">
<i class="fas fa-envelope"></i> Contact Us
</h2>

<p class="contact-subtitle">
Have questions? Get in touch with us.
</p>

<div class="row">

<div class="col">

<div class="contact-card">

<form>

<label>Name</label> <input type="text" placeholder="Enter your name">

<label>Email</label> <input type="email" placeholder="Enter your email">

<label>Message</label>

<textarea rows="5" placeholder="Write your message"></textarea>

<button class="contact-btn">
Send Message
</button>

</form>

</div>

</div>

<div class="col">

<div class="store-info">

<h4>Store Information</h4>

<p><i class="fas fa-map-marker-alt"></i> Ahmedabad, Gujarat</p>

<p><i class="fas fa-phone"></i> +91 9876543210</p>

<p><i class="fas fa-envelope"></i> support@grocerystore.com</p>

</div>

</div>

</div>

</div>

</div>

</body>
</html>
