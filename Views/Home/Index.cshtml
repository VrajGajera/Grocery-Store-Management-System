@{
ViewData["Title"] = "Home";
}
@model IEnumerable<Grosary_net.Models.Product>

<!-- HERO SECTION -->

<div class="hero-section">
    <img src="https://images.unsplash.com/photo-1542838132-92c53300491e?w=1400" class="hero-bg" alt="Grocery Store">

```
<div class="hero-overlay">
    <div class="container text-center text-white">
        <h1 class="display-4 fw-bold">Welcome to GroceryStore</h1>
        <p class="lead text-light">Your one-stop shop for fresh groceries</p>

        <p class="mt-3">
            Shop from our wide range of fresh fruits, vegetables, dairy products and more.
            We deliver quality groceries right to your doorstep.
        </p>

        <div class="mt-4">
            <a href="/Account/Register" class="btn btn-lg me-3 hero-btn-green">
                <i class="fas fa-user-plus me-2"></i>Get Started
            </a>

            <a href="/Account/SignIn" class="btn btn-lg hero-btn-dark" autocomplete="off">
                <i class="fas fa-sign-in-alt me-2"></i>Login
            </a>
        </div>
    </div>
</div>
```

</div>

